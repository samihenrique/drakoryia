{
  "name": "drakoryia",
  "version": "0.1.0",
  "description": "The local command center for AI coding agents.",
  "author": "Sami Henrique",
  "desktopName": "drakoryia",
  "main": "./out/main/index.js",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "postinstall": "pnpm prisma:generate && electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "pnpm prisma:generate && pnpm typecheck && electron-vite build",
    "start": "electron-vite preview",
    "package": "pnpm build && electron-builder --config",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "prisma": "7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@swc/core": "1.15.43",
    "@tailwindcss/vite": "4.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "shadcn": "4.13.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "7.3.6"
  },
  "build": {
    "appId": "com.drakoryia.app",
    "productName": "Drakoryia",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "prisma/**/*",
      "prisma.config.ts",
      "package.json"
    ],
    "asarUnpack": [
      "prisma/**/*",
      "prisma.config.ts",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "design/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "design/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "design/app-icon.png",
      "category": "Development",
      "synopsis": "The local command center for AI coding agents.",
      "syncDesktopName": true,
      "target": [
        "AppImage"
      ]
    }
  }
}
