generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ApplicationSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Workspace {
  id         String    @id @default(cuid())
  name       String
  localPath  String    @unique
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
